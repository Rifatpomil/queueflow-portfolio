# ──────────────────────────────────────────────────────────────────────────────
# QueueFlow – Environment Variables
# Copy to .env and fill in values. Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=queueflow
POSTGRES_PASSWORD=queueflow_dev_secret
POSTGRES_DB=queueflow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# AUTH_MODE: "dev" uses local HS256 JWTs; "keycloak" validates against Keycloak
AUTH_MODE=dev
JWT_SECRET_KEY=dev-super-secret-key-change-in-prod-32chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Keycloak (only needed when AUTH_MODE=keycloak) ───────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=queueflow
KEYCLOAK_CLIENT_ID=queueflow-api
KEYCLOAK_CLIENT_SECRET=

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
RATE_LIMIT_ENABLED=true
