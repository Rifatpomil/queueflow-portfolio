APP_ENV=development
DATABASE_URL=postgresql+asyncpg://queueflow:queueflow_dev_secret@localhost:5432/queueflow
DATABASE_SYNC_URL=postgresql+psycopg2://queueflow:queueflow_dev_secret@localhost:5432/queueflow
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
JWT_SECRET_KEY=dev-super-secret-key-change-in-prod-32chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
AUTH_MODE=dev
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=queueflow
KEYCLOAK_CLIENT_ID=queueflow-api
KEYCLOAK_CLIENT_SECRET=
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=true

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=queueflow-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Postgres RLS (optional, defense in depth)
RLS_ENABLED=false
