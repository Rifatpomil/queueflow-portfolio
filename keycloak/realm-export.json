{
  "realm": "queueflow",
  "enabled": true,
  "displayName": "QueueFlow",
  "ssoSessionIdleTimeout": 1800,
  "accessTokenLifespan": 3600,
  "clients": [
    {
      "clientId": "queueflow-api",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "queueflow-frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin",   "description": "Full system access" },
      { "name": "manager", "description": "Location management" },
      { "name": "staff",   "description": "Queue operations" },
      { "name": "viewer",  "description": "Read-only / signage" }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@queueflow.dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "System",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "realmRoles": ["admin"]
    },
    {
      "username": "manager",
      "email": "manager@queueflow.dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Location",
      "lastName": "Manager",
      "credentials": [{ "type": "password", "value": "manager123", "temporary": false }],
      "realmRoles": ["manager"]
    },
    {
      "username": "staff",
      "email": "staff@queueflow.dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Staff",
      "lastName": "Member",
      "credentials": [{ "type": "password", "value": "staff123", "temporary": false }],
      "realmRoles": ["staff"]
    },
    {
      "username": "viewer",
      "email": "viewer@queueflow.dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Signage",
      "lastName": "Viewer",
      "credentials": [{ "type": "password", "value": "viewer123", "temporary": false }],
      "realmRoles": ["viewer"]
    }
  ]
}
